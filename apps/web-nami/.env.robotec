PRODUCT_CARD_CODE=true
PRODUCT_DETAIL_PRICE_TYPE=with_tax
PRODUCT_DETAIL_RELATED_PRODUCTS=true
PRODUCT_DETAIL_STOCK=true
PRODUCT_PAGINATION=true

# Features
CART_ENABLED=true
AUTH_ENABLED=true

# Payment Methods
PAYMENT_METHODS=SADE,ITDE,ABGI

