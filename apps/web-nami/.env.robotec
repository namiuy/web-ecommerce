# API Configuration for Next.js API Routes - Local Development
# API_BASE_URL_RAW is used for auth endpoints that already include /api in their path
API_BASE_URL_RAW=http://localhost:8000
# NEXT_PUBLIC_API_BASE_URL and API_BASE_URL include /api for other endpoints
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
API_BASE_URL=http://localhost:8000/api
API_PATH=/api
IMAGES_URL=https://robotec-uy.s3.sa-east-1.amazonaws.com/products
BRANDS_URL=https://robotec-uy.s3.sa-east-1.amazonaws.com/brands

# Application Configuration
