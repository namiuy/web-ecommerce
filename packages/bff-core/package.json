{
  "name": "@namiuy/bff-core",
  "version": "1.0.0",
  "description": "Core domain types and interfaces for BFF layer",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": "./dist/index.js",
    "./entities": "./dist/entities/index.js",
    "./repositories": "./dist/repositories/index.js",
    "./types": "./dist/types/index.js"
  },
  "typesVersions": {
    "*": {
      "entities": ["./dist/entities/index.d.ts"],
      "repositories": ["./dist/repositories/index.d.ts"],
      "types": ["./dist/types/index.d.ts"]
    }
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependencies": {},
  "keywords": [
    "bff",
    "domain",
    "entities",
    "repositories"
  ]
}
